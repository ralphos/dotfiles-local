# recommended by brew doctor
# Prepend system paths rather than replacing the entire PATH
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Invoke commands without the bin/ prefix
export PATH="./bin:$PATH"

# Pretty print JSON
function pjson {
  if [ $# -gt 0 ]; then
    for arg in $@; do
      if [ -f $arg ]; then
        less $arg | python3 -m json.tool
      else
        echo "$arg" | python3 -m json.tool
      fi
    done
  fi
}

# Prompt
export PS1='${SSH_CONNECTION+"%{$fg_bold[green]%}%n@%m:"}%{$fg_bold[blue]%}%c%{$reset_color%}$(git_prompt_info) '

# Postgres 15
export PATH="/usr/local/opt/postgresql@15/bin:$PATH"

# Windsurf
export PATH="$HOME/.codeium/windsurf/bin:$PATH"

# Claude Code
export PATH="$HOME/Library/Application Support/Claude/claude-code/2.1.49:$PATH"

# Local bins
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/bin:$PATH"

# Re-prepend asdf shims so they win over /usr/bin/ruby and similar.
# Upstream zshrc puts asdf shims before sourcing this file, but the
# personal PATH prepends above bury them under system paths.
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
